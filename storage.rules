rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Uploaded partner documents (max 20 MB per file).
    match /documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
